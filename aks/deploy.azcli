#!/usr/bin/env bash
# ============================================================
# Fabric Data Agent - AKS 배포 스크립트
# ============================================================
set -euo pipefail

# ── 변수 ────────────────────────────────────────────────────
RESOURCE_GROUP="AZ-AKS-RG"
CLUSTER_NAME="mskr-aks-cluster"
ACR_NAME=""                          # TODO: ACR 이름 입력 (예: mskracr)
IMAGE_TAG="latest"
IMAGE_NAME="fabric-data-agent"
NAMESPACE="fabric-data-agent"
SA_NAME="fabric-data-agent-sa"

UAMI_NAME="mskr-aks-cluster-uami"
UAMI_CLIENT_ID="1cdb01c5-ab92-457a-b1a7-ce84cf1c8789"
SUBSCRIPTION_ID="85065b6a-4de1-4e07-a857-c41de5eadee8"

DNS_ZONE="mskr-datanai.net"
DNS_RG="az-managemet-rg"
DNS_RECORD="dataagent"
LB_IP="20.249.146.99"

PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# ── AKS 자격증명 ────────────────────────────────────────────
echo "[1/7] AKS 자격증명 가져오기..."
az aks get-credentials \
  --resource-group "$RESOURCE_GROUP" \
  --name "$CLUSTER_NAME" \
  --overwrite-existing
kubelogin convert-kubeconfig -l devicecode

# ── Federated Credential 등록 (최초 1회) ───────────────────
echo "[2/7] Workload Identity Federated Credential 확인/등록..."
OIDC_ISSUER=$(az aks show \
  --resource-group "$RESOURCE_GROUP" \
  --name "$CLUSTER_NAME" \
  --query "oidcIssuerProfile.issuerUrl" -o tsv)

echo "  OIDC Issuer: $OIDC_ISSUER"

FEDERATED_NAME="fabric-data-agent-federated"
EXISTING=$(az identity federated-credential list \
  --identity-name "$UAMI_NAME" \
  --resource-group "$RESOURCE_GROUP" \
  --query "[?name=='$FEDERATED_NAME'].name" -o tsv 2>/dev/null || true)

if [ -z "$EXISTING" ]; then
  echo "  Federated Credential 생성 중..."
  az identity federated-credential create \
    --name "$FEDERATED_NAME" \
    --identity-name "$UAMI_NAME" \
    --resource-group "$RESOURCE_GROUP" \
    --issuer "$OIDC_ISSUER" \
    --subject "system:serviceaccount:${NAMESPACE}:${SA_NAME}" \
    --audiences "api://AzureADTokenExchange"
  echo "  Federated Credential 생성 완료"
else
  echo "  Federated Credential 이미 존재함, 건너뜀"
fi

# ── DNS A 레코드 등록 ────────────────────────────────────────
echo "[3/7] DNS A 레코드 등록 (${DNS_RECORD}.${DNS_ZONE} → ${LB_IP})..."
az network dns record-set a add-record \
  --resource-group "$DNS_RG" \
  --zone-name "$DNS_ZONE" \
  --record-set-name "$DNS_RECORD" \
  --ipv4-address "$LB_IP" \
  --if-none-match 2>/dev/null || echo "  DNS 레코드 이미 존재함"

# ── Docker 이미지 빌드 & ACR Push ───────────────────────────
echo "[4/7] Docker 이미지 빌드 & ACR 푸시..."
if [ -z "$ACR_NAME" ]; then
  echo "  [ERROR] ACR_NAME 변수를 설정해 주세요 (이 스크립트 상단)"
  exit 1
fi

ACR_LOGIN_SERVER="${ACR_NAME}.azurecr.io"
az acr login --name "$ACR_NAME"

docker build -t "${ACR_LOGIN_SERVER}/${IMAGE_NAME}:${IMAGE_TAG}" "$PROJECT_DIR"
docker push "${ACR_LOGIN_SERVER}/${IMAGE_NAME}:${IMAGE_TAG}"

# ── deployment.yaml 이미지 주소 치환 ────────────────────────
sed -i.bak \
  "s|<ACR_LOGIN_SERVER>|${ACR_LOGIN_SERVER}|g" \
  "$PROJECT_DIR/aks/deployment.yaml"

# ── Kubernetes 매니페스트 적용 ───────────────────────────────
echo "[5/7] Kubernetes 매니페스트 적용..."
kubectl apply -f "$PROJECT_DIR/aks/namespace.yaml"
kubectl apply -f "$PROJECT_DIR/aks/serviceaccount.yaml"
kubectl apply -f "$PROJECT_DIR/aks/deployment.yaml"
kubectl apply -f "$PROJECT_DIR/aks/service.yaml"
kubectl apply -f "$PROJECT_DIR/aks/ingress.yaml"

# ── CoreDNS Hairpin NAT 업데이트 ────────────────────────────
echo "[6/7] CoreDNS Hairpin NAT에 dataagent 추가..."
kubectl get cm coredns-custom -n kube-system -o yaml | \
  grep -q "dataagent.mskr-datanai.net" && \
  echo "  CoreDNS에 이미 등록됨, 건너뜀" || \
  kubectl patch cm coredns-custom -n kube-system --type=merge -p "
data:
  mskr-datanai.override: |
    hosts {
        10.0.222.172  superset.mskr-datanai.net
        10.0.222.172  n8n.mskr-datanai.net
        10.0.222.172  dataagent.mskr-datanai.net
        fallthrough
    }
"
kubectl rollout restart deployment coredns -n kube-system

# ── 배포 대기 ────────────────────────────────────────────────
echo "[7/7] 배포 완료 대기..."
kubectl rollout status deployment/fabric-data-agent -n fabric-data-agent --timeout=3m

echo ""
echo "✅ 배포 완료!"
echo "   URL: https://dataagent.mskr-datanai.net"
echo "   (TLS 인증서 발급까지 약 1-2분 소요)"
